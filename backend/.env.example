# .env.example
# Copy this file to .env for local development.
# Never commit .env — it contains real secrets.
# In production (Railway), set these as environment variables in the dashboard.

# ─── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token — needs repo:read scope for the sync job.
# Create at: https://github.com/settings/tokens/new
GITHUB_TOKEN=

# Anthropic API key — used by the AI description generation service.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# PostgreSQL connection string.
# Railway injects this automatically when you add the Postgres plugin.
# Local example: postgresql://postgres:password@localhost:5432/nocos
DATABASE_URL=

# ─── Optional ─────────────────────────────────────────────────────────────────

# GitLab personal access token — requires read_api scope.
# Optional: without it, GitLab scraping runs unauthenticated (~60 req/min).
# Create at: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=

# ─── Optional (auto-provided by Railway plugins) ───────────────────────────────

# Redis connection string.
# Railway injects this automatically when you add the Redis plugin.
# Local example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ────────────────────────────────────────────────────────────

# Resend API key for the subscribe confirmation email.
# Get from: https://resend.com/api-keys
EMAIL_SERVICE_API_KEY=

# From address shown in emails — must be a verified domain in Resend.
EMAIL_FROM=hello@nocos.cc

# ─── Admin ─────────────────────────────────────────────────────────────────────

# Secret token protecting the content moderation endpoints (/api/v1/admin/*).
# If unset, all admin endpoints return 503. Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=

# ─── App ───────────────────────────────────────────────────────────────────────

# Set to "production" on Railway. Leave as "development" locally.
APP_ENV=development

# Base URL of the frontend — used in email confirmation links.
# In production this is https://nocos.cc
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public frontend URL — used in admin approval emails to link back to the task.
# In production this is https://nocos.cc
FRONTEND_URL=https://nocos.cc
