# .gitignore — Python + Node environments
# Covers both /backend (Python) and /frontend (Node.js/Next.js)

# ─── Environment Variables ───────────────────────────────────────────────────
# NEVER commit .env files — they contain secrets
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

