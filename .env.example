# .env.example
# Copy this file to .env and fill in your own values.
# Never commit the actual .env file — it's in .gitignore.
#
# See CONTRIBUTING.md for setup instructions.

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token (classic) — create at github.com/settings/tokens
# Required scopes: public_repo (read-only is sufficient — Nocos never writes to GitHub)
GITHUB_TOKEN=

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Claude API key — create at console.anthropic.com
# Used to generate plain-English descriptions for GitHub issues with missing bodies.
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example: postgresql://user:password@localhost:5432/nocos
DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string — used to cache GitHub API responses and prevent rate limiting
# Local example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Email ────────────────────────────────────────────────────────────────────
# Resend or SendGrid API key — used for confirmation emails and weekly digests
EMAIL_SERVICE_API_KEY=
# Sender address shown in outgoing emails
EMAIL_FROM=hello@nocos.io

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Backend API base URL — the frontend uses this to make API calls
# Development: http://localhost:8000
# Production: https://api.nocos.cc (or your backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── App ──────────────────────────────────────────────────────────────────────
# Environment mode — controls CORS policy, API docs visibility, and log verbosity
# Values: development | production
APP_ENV=development
